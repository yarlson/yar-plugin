<idea-plugin>
    <id>dev.yarlson.yar</id>
    <name>Yar</name>
    <vendor url="https://yarlson.dev">yarlson.dev</vendor>

    <description><![CDATA[
      Language support for the <b>Yar</b> programming language.
      <ul>
        <li>Syntax and semantic highlighting</li>
        <li>Code parsing and error recovery</li>
        <li>Brace matching</li>
        <li>Line commenting</li>
        <li>Code folding</li>
        <li>Structure view</li>
        <li>Configurable color scheme</li>
        <li>Go to definition</li>
        <li>Find usages</li>
        <li>Go to symbol</li>
        <li>Rename refactoring</li>
      </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File Type -->
        <fileType name="Yar"
                  implementationClass="dev.yarlson.yar.YarFileType"
                  fieldName="INSTANCE"
                  language="Yar"
                  extensions="yar"/>

        <!-- Parser -->
        <lang.parserDefinition language="Yar"
                               implementationClass="dev.yarlson.yar.parser.YarParserDefinition"/>

        <!-- Syntax Highlighting -->
        <lang.syntaxHighlighterFactory language="Yar"
                                       implementationClass="dev.yarlson.yar.highlighting.YarSyntaxHighlighterFactory"/>

        <!-- Brace Matching -->
        <lang.braceMatcher language="Yar"
                           implementationClass="dev.yarlson.yar.editor.YarBraceMatcher"/>

        <!-- Commenter -->
        <lang.commenter language="Yar"
                        implementationClass="dev.yarlson.yar.editor.YarCommenter"/>

        <!-- Color Settings Page -->
        <colorSettingsPage implementation="dev.yarlson.yar.highlighting.YarColorSettingsPage"/>

        <!-- Code Folding -->
        <lang.foldingBuilder language="Yar"
                             implementationClass="dev.yarlson.yar.editor.YarFoldingBuilder"/>

        <!-- Structure View -->
        <lang.psiStructureViewFactory language="Yar"
                                      implementationClass="dev.yarlson.yar.structure.YarStructureViewFactory"/>

        <!-- Semantic Annotator -->
        <annotator language="Yar"
                   implementationClass="dev.yarlson.yar.highlighting.YarAnnotator"/>

        <!-- References -->
        <psi.referenceContributor language="Yar"
                                  implementation="dev.yarlson.yar.references.YarReferenceContributor"/>

        <!-- Find Usages -->
        <lang.findUsagesProvider language="Yar"
                                 implementationClass="dev.yarlson.yar.navigation.YarFindUsagesProvider"/>

        <!-- Go to Symbol -->
        <gotoSymbolContributor
                implementation="dev.yarlson.yar.navigation.YarGoToSymbolContributor"/>
    </extensions>
</idea-plugin>
